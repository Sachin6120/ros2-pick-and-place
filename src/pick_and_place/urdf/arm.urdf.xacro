<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="pick_place_arm">

  <!-- ================= PARAMETERS ================= -->
  <xacro:property name="base_height" value="0.05"/>
  <xacro:property name="base_radius" value="0.08"/>
  <xacro:property name="link1_length" value="0.30"/>
  <xacro:property name="link1_radius" value="0.04"/>
  <xacro:property name="link2_length" value="0.25"/>
  <xacro:property name="link2_radius" value="0.035"/>
  <xacro:property name="link3_length" value="0.20"/>
  <xacro:property name="link3_radius" value="0.03"/>
  <xacro:property name="gripper_width" value="0.08"/>
  <xacro:property name="finger_length" value="0.06"/>
  <xacro:property name="finger_width" value="0.01"/>
 

  <!-- ================= INERTIA MACROS ================= -->
  <xacro:macro name="cylinder_inertia" params="mass length radius">
    <inertial>
      <origin xyz="0 0 ${length/2}"/>
      <mass value="${mass}"/>
      <inertia ixx="${(1.0/12.0)*mass*(3*radius*radius + length*length)}"
               iyy="${(1.0/12.0)*mass*(3*radius*radius + length*length)}"
               izz="${0.5*mass*radius*radius}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(1.0/12.0)*mass*(y*y + z*z)}"
               iyy="${(1.0/12.0)*mass*(x*x + z*z)}"
               izz="${(1.0/12.0)*mass*(x*x + y*y)}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ================= WORLD ================= -->
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_height/2}"/>
  </joint>

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual><geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry></visual>
    <collision><geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry></collision>
    <xacro:cylinder_inertia mass="2.0" length="${base_height}" radius="${base_radius}"/>
  </link>

  <!-- ================= ARM ================= -->
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 ${base_height/2}"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="100.0" velocity="2.0"/>
    <dynamics damping="3.0"/>
  </joint>

  <link name="link1">
    <visual><origin xyz="0 0 ${link1_length/2}"/><geometry><cylinder radius="${link1_radius}" length="${link1_length}"/></geometry></visual>
    <collision><origin xyz="0 0 ${link1_length/2}"/><geometry><cylinder radius="${link1_radius}" length="${link1_length}"/></geometry></collision>
    <xacro:cylinder_inertia mass="1.5" length="${link1_length}" radius="${link1_radius}"/>
  </link>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 ${link1_length}"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="100.0" velocity="2.0"/>
    <dynamics damping="5.0"/>
  </joint>

  <link name="link2">
    <visual><origin xyz="0 0 ${link2_length/2}"/><geometry><cylinder radius="${link2_radius}" length="${link2_length}"/></geometry></visual>
    <collision><origin xyz="0 0 ${link2_length/2}"/><geometry><cylinder radius="${link2_radius}" length="${link2_length}"/></geometry></collision>
    <xacro:cylinder_inertia mass="1.0" length="${link2_length}" radius="${link2_radius}"/>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 ${link2_length}"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-2*pi/3}" upper="${2*pi/3}" effort="100.0" velocity="2.0"/>
    <dynamics damping="3.0"/>
  </joint>

  <link name="link3">
    <visual><origin xyz="0 0 ${link3_length/2}"/><geometry><cylinder radius="${link3_radius}" length="${link3_length}"/></geometry></visual>
    <collision><origin xyz="0 0 ${link3_length/2}"/><geometry><cylinder radius="${link3_radius}" length="${link3_length}"/></geometry></collision>
    <xacro:cylinder_inertia mass="0.8" length="${link3_length}" radius="${link3_radius}"/>
  </link>

  <!-- ================= EE ================= -->
  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link3"/>
    <child link="ee_link"/>
    <origin xyz="0 0 ${link3_length}"/>
  </joint>

  <link name="ee_link">
    <visual><geometry><sphere radius="0.01"/></geometry></visual>
  </link>

  <!-- ================= GRIPPER (FIXED) ================= -->
  <joint name="palm_joint" type="fixed">
    <parent link="ee_link"/>
    <child link="gripper_palm"/>
    <origin xyz="0 0 0.01" rpy="0 -1.5708 0"/>
  </joint>

  <link name="gripper_palm">
    <visual><geometry><box size="0.06 ${gripper_width} 0.02"/></geometry></visual>
    <collision><geometry><box size="0.06 ${gripper_width} 0.02"/></geometry></collision>
    <xacro:box_inertia mass="0.3" x="0.06" y="${gripper_width}" z="0.02"/>
  </link>

  <!-- LEFT -->
  <joint name="left_finger_joint" type="prismatic">
    <origin xyz="0 ${gripper_width/2} 0"/>
    <axis xyz="0 -1 0"/>
    <parent link="gripper_palm"/>
    <child link="left_finger"/>
    <limit lower="0.0" upper="0.04" effort="50" velocity="0.5"/>
    <dynamics damping="2.0"/>
  </joint>

  <link name="left_finger">
    <visual><origin xyz="${finger_length/2} 0 0"/><geometry><box size="${finger_length} 0.02 ${finger_width}"/></geometry></visual>
    <collision><origin xyz="${finger_length/2} 0 0"/><geometry><box size="${finger_length} 0.02 ${finger_width}"/></geometry></collision>
    <xacro:box_inertia mass="0.1" x="${finger_length}" y="0.02" z="${finger_width}"/>
  </link>

  <!-- RIGHT -->
  <joint name="right_finger_joint" type="prismatic">
    <origin xyz="0 ${-gripper_width/2} 0"/>
    <axis xyz="0 1 0"/>
    <parent link="gripper_palm"/>
    <child link="right_finger"/>
    <mimic joint="left_finger_joint"/>
    <limit lower="0.0" upper="0.04" effort="50" velocity="0.5"/>
    <dynamics damping="2.0"/>
  </joint>

  <link name="right_finger">
    <visual><origin xyz="${finger_length/2} 0 0"/><geometry><box size="${finger_length} 0.02 ${finger_width}"/></geometry></visual>
    <collision><origin xyz="${finger_length/2} 0 0"/><geometry><box size="${finger_length} 0.02 ${finger_width}"/></geometry></collision>
    <xacro:box_inertia mass="0.1" x="${finger_length}" y="0.02" z="${finger_width}"/>
  </link>

  <xacro:include filename="$(find pick_and_place)/urdf/arm.gazebo.xacro"/>
  <xacro:include filename="$(find pick_and_place)/urdf/arm.ros2_control.xacro"/>

</robot>